# Auto-Print Agent — environment configuration (copy to .env and fill in)
#
# These are read by agent.py when you prefix the command with them, e.g.:
#   RELAY_URL=https://your-app.vercel.app AGENT_TOKEN=xxxx python3 agent.py
#
# (agent.py also accepts --relay and --token flags.)

# Your deployed Vercel URL
RELAY_URL=https://your-app.vercel.app

# Must match the AGENT_TOKEN environment variable set in your Vercel project
AGENT_TOKEN=change-me-to-a-long-random-string
